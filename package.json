{
  "name": "@kirill.konshin/utils-monorepo",
  "description": "Utils Monorepo",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "prepare": "yarn prepare:agents && yarn prepare:nx && yarn prepare:eslint && yarn prepare:husky",
    "prepare:agents": "node packages/agents/bin/index.js init",
    "prepare:nx": "nx show projects > /dev/null",
    "prepare:eslint": "node packages/eslint-config-next-custom/install.js",
    "prepare:husky": "husky",
    "----- LINT -----": "",
    "eslint": "eslint --fix --concurrency=auto --cache --cache-location node_modules/.cache/eslint",
    "prettier": "prettier --write --log-level=warn --ignore-path .gitignore --ignore-path .prettierignore",
    "lint": "yarn eslint . && yarn prettier .",
    "lint:staged": "lint-staged --debug",
    "----- RELEASE -----": "",
    "release": "nx release",
    "release:preview": "nx release --dry-run --verbose",
    "commitlint": "commitlint",
    "----- TASKS -----": "",
    "start": "nx run-many -t start --parallel=100",
    "build": "nx run-many -t build",
    "test": "nx run-many -t test --parallel=1",
    "serve": "nx run-many -t serve",
    "----- TASKS: PACKAGES ONLY -----": "",
    "start:packages": "yarn start --projects '@kirill.konshin/*'",
    "build:packages": "yarn build --projects '@kirill.konshin/*'",
    "----- TASKS: AFFECTED (CI) -----": "",
    "test:affected": "nx affected -t test --parallel=1 --exclude '@demo/*'",
    "build:affected": "nx affected -t build --exclude '@demo/*'"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@nx/js": "^23.1.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.9",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.4",
    "nx": "^23.1.0",
    "prettier": "^3.6.2",
    "react": "^19.1.1",
    "typescript": "^5.9.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "wait-on": "^9.0.10"
  },
  "author": "Kirill Konshin <kirill@konshin.org> (https://konshin.org)",
  "license": "MIT",
  "packageManager": "yarn@4.9.2",
  "workspaces": {
    "packages": [
      "demo/*",
      "packages/*"
    ]
  },
  "overrides": {
    "@types/node": "$@types/node",
    "@types/react": "$@types/react",
    "@types/react-dom": "$@types/react-dom",
    "next": "$next",
    "eslint": "$eslint",
    "typescript": "$typescript",
    "vite": "$vite"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kirill-konshin/utils.git"
  }
}
