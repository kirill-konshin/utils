{
  "name": "@kirill.konshin/utils-monorepo",
  "description": "Utils Monorepo",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "----- LINT -----": "",
    "prepare": "husky",
    "eslint": "eslint --fix --concurrency=auto --cache --cache-location node_modules/.cache/eslint",
    "prettier": "prettier --write --log-level=warn --ignore-path .gitignore --ignore-path .prettierignore",
    "lint:all": "yarn eslint . && yarn prettier .",
    "lint:staged": "lint-staged --debug",
    "----- CHANGESETS -----": "",
    "release-version": "changeset version && yarn",
    "release": "changeset publish",
    "changeset": "changeset",
    "----- TURBO -----": "",
    "start": "turbo run start",
    "build": "turbo run build --concurrency=1",
    "test": "turbo run test --concurrency=1",
    "serve": "turbo run serve"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@changesets/cli": "^2.30.0",
    "@types/react": "^19.1.9",
    "ctix": "2.6.4",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.4",
    "prettier": "^3.6.2",
    "react": "^19.1.1",
    "turbo": "^2.5.5",
    "typescript": "^5.9.2",
    "vite": "^7.0.6",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.4"
  },
  "author": "Kirill Konshin <kirill@konshin.org> (https://konshin.org)",
  "license": "MIT",
  "packageManager": "yarn@4.9.2",
  "workspaces": {
    "packages": [
      "demo/*",
      "packages/*"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kirill-konshin/utils.git"
  }
}
